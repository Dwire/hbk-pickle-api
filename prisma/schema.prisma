generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  ADMIN
}

enum RegistrationStatus {
  ATTENDING
  DECLINED
  CANCELED
}

enum SubSignupStatus {
  ACTIVE
  CANCELED
  SELECTED
  REPLACED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationKind {
  REGISTRATION_CLOSE_WARNING
  SESSION_START_WARNING
  SUB_SELECTED
  SUB_STATUS_CHANGED
}

enum NotificationChannel {
  PUSH
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model User {
  id             String   @id @default(uuid())
  phoneNumber    String   @unique
  displayName    String?
  role           UserRole @default(PLAYER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  slotAssignments SlotAssignment[]
  registrations  SessionRegistration[]
  subSignups     SubSignup[]
  devices        UserDevice[]
  notifications  Notification[]
}

model UserDevice {
  id          String   @id @default(uuid())
  userId      String
  token       String   @unique
  platform    String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model League {
  id          String   @id @default(uuid())
  name        String
  isActive    Boolean  @default(true)
  startDate   DateTime?
  endDate     DateTime?
  timeZone    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  rules       LeagueRule[]
  sessions    Session[]
  assignments SlotAssignment[]
}

model LeagueRule {
  id        String   @id @default(uuid())
  leagueId  String
  title     String
  body      String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  league    League   @relation(fields: [leagueId], references: [id])

  @@unique([leagueId, order])
}

model Session {
  id          String   @id @default(uuid())
  leagueId    String
  title       String
  weekday     Weekday
  startTimeMinutes Int
  endTimeMinutes Int
  capacity    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  league      League   @relation(fields: [leagueId], references: [id])
  occurrences SessionOccurrence[]
  assignments SlotAssignment[]
}

model SessionOccurrence {
  id         String   @id @default(uuid())
  sessionId  String
  startsAt   DateTime
  endsAt     DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  session    Session  @relation(fields: [sessionId], references: [id])
  registrations SessionRegistration[]
  subSignups  SubSignup[]
  notifications Notification[]

  @@unique([sessionId, startsAt])
}

model SlotAssignment {
  id        String   @id @default(uuid())
  leagueId  String
  userId    String
  sessionId String
  createdAt DateTime @default(now())
  league    League   @relation(fields: [leagueId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  session   Session  @relation(fields: [sessionId], references: [id])

  @@unique([leagueId, userId])
}

model SessionRegistration {
  id           String             @id @default(uuid())
  userId       String
  occurrenceId String
  status       RegistrationStatus
  updatedAt    DateTime           @updatedAt
  createdAt    DateTime           @default(now())
  user         User               @relation(fields: [userId], references: [id])
  occurrence   SessionOccurrence  @relation(fields: [occurrenceId], references: [id])

  @@unique([userId, occurrenceId])
}

model SubSignup {
  id         String          @id @default(uuid())
  userId     String
  occurrenceId String
  status     SubSignupStatus
  signedUpAt DateTime        @default(now())
  selectionRank Int?
  selectedAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id])
  occurrence SessionOccurrence @relation(fields: [occurrenceId], references: [id])

  @@unique([userId, occurrenceId])
}

model Notification {
  id         String              @id @default(uuid())
  userId     String
  occurrenceId  String?
  title      String
  body       String
  channel    NotificationChannel
  status     NotificationStatus
  kind       NotificationKind
  payload    Json?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  user       User                @relation(fields: [userId], references: [id])
  occurrence SessionOccurrence?  @relation(fields: [occurrenceId], references: [id])
}
