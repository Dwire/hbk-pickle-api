generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLAYER
  ADMIN
}

enum RegistrationStatus {
  ATTENDING
  DECLINED
  CANCELED
}

enum SubSignupStatus {
  ACTIVE
  CANCELED
  SELECTED
  REPLACED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationChannel {
  PUSH
}

model User {
  id             String   @id @default(uuid())
  phoneNumber    String   @unique
  displayName    String?
  role           UserRole @default(PLAYER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  assignedSlot   SlotAssignment?
  registrations  SessionRegistration[]
  subSignups     SubSignup[]
  devices        UserDevice[]
  notifications  Notification[]
}

model UserDevice {
  id          String   @id @default(uuid())
  userId      String
  token       String   @unique
  platform    String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model League {
  id          String   @id @default(uuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  rules       LeagueRule[]
  sessions    Session[]
  assignments SlotAssignment[]
}

model LeagueRule {
  id        String   @id @default(uuid())
  leagueId  String
  title     String
  body      String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  league    League   @relation(fields: [leagueId], references: [id])

  @@unique([leagueId, order])
}

model Session {
  id          String   @id @default(uuid())
  leagueId    String
  title       String
  startTime   DateTime
  endTime     DateTime
  capacity    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  league      League   @relation(fields: [leagueId], references: [id])
  registrations SessionRegistration[]
  subSignups  SubSignup[]
  assignments SlotAssignment[]
  notifications Notification[]
}

model SlotAssignment {
  id        String   @id @default(uuid())
  leagueId  String
  userId    String   @unique
  sessionId String
  createdAt DateTime @default(now())
  league    League   @relation(fields: [leagueId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  session   Session  @relation(fields: [sessionId], references: [id])
}

model SessionRegistration {
  id           String             @id @default(uuid())
  userId       String
  sessionId    String
  status       RegistrationStatus
  updatedAt    DateTime           @updatedAt
  createdAt    DateTime           @default(now())
  user         User               @relation(fields: [userId], references: [id])
  session      Session            @relation(fields: [sessionId], references: [id])

  @@unique([userId, sessionId])
}

model SubSignup {
  id         String          @id @default(uuid())
  userId     String
  sessionId  String
  status     SubSignupStatus
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id])
  session    Session         @relation(fields: [sessionId], references: [id])

  @@unique([userId, sessionId])
}

model Notification {
  id         String              @id @default(uuid())
  userId     String
  sessionId  String?
  title      String
  body       String
  channel    NotificationChannel
  status     NotificationStatus
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  user       User                @relation(fields: [userId], references: [id])
  session    Session?            @relation(fields: [sessionId], references: [id])
}
