generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeagueStatus {
  DRAFT
  UPCOMING
  ACTIVE
  ARCHIVED
}

enum SessionStatus {
  ACTIVE
  ARCHIVED
}

enum RegistrationStatus {
  ATTENDING
  DECLINED
  CANCELED
}

enum SubSignupStatus {
  ACTIVE
  CANCELED
  SELECTED
  REPLACED
}

enum SessionOccurrenceStatus {
  ACTIVE
  CANCELED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationKind {
  REGISTRATION_CLOSE_WARNING
  SESSION_START_WARNING
  SUB_SELECTED
  SUB_STATUS_CHANGED
  SESSION_CANCELED
}

enum NotificationChannel {
  PUSH
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum OrganizationMembershipRole {
  OWNER
  ADMIN
}

enum LeagueMembershipStatus {
  ACTIVE
  REMOVED
}

model User {
  id                      String                   @id @default(uuid()) @db.Uuid
  phoneNumber             String                   @unique
  displayName             String?
  profileImageId          String?                  @unique
  isOnApp                 Boolean                  @default(false)
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  slotAssignments         SlotAssignment[]
  registrations           SessionRegistration[]
  subSignups              SubSignup[]
  devices                 UserDevice[]
  notifications           Notification[]
  organizationMemberships OrganizationMembership[]
  leagueMemberships       LeagueMembership[]
  profilePhotoUploadIntents ProfilePhotoUploadIntent[]
}

model ProfilePhotoUploadIntent {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  providerImageId String   @unique
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt, expiresAt])
}

model UserDevice {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  token       String   @unique
  platform    String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model League {
  id          String             @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid
  name        String
  status      LeagueStatus       @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  timeZone    String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  organization Organization      @relation(fields: [organizationId], references: [id])
  rules       LeagueRule[]
  sessions    Session[]
  assignments SlotAssignment[]
  memberships LeagueMembership[]

  @@index([status])
  @@index([organizationId, status])
}

model Organization {
  id          String                   @id @default(uuid()) @db.Uuid
  name        String
  slug        String                   @unique
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  leagues     League[]
  memberships OrganizationMembership[]
}

model OrganizationMembership {
  id             String                   @id @default(uuid()) @db.Uuid
  organizationId String                   @db.Uuid
  userId         String                   @db.Uuid
  role           OrganizationMembershipRole
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  organization   Organization             @relation(fields: [organizationId], references: [id])
  user           User                     @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
}

model LeagueMembership {
  id         String                 @id @default(uuid()) @db.Uuid
  leagueId   String                 @db.Uuid
  userId     String                 @db.Uuid
  status     LeagueMembershipStatus @default(ACTIVE)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  league     League                 @relation(fields: [leagueId], references: [id])
  user       User                   @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
  @@index([userId, status])
}

model LeagueRule {
  id        String   @id @default(uuid()) @db.Uuid
  leagueId  String   @db.Uuid
  title     String
  body      String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  league    League   @relation(fields: [leagueId], references: [id])

  @@unique([leagueId, order])
}

model Session {
  id          String   @id @default(uuid()) @db.Uuid
  leagueId    String   @db.Uuid
  status      SessionStatus @default(ACTIVE)
  title       String
  weekday     Weekday
  startTimeMinutes Int
  endTimeMinutes Int
  capacity    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  league      League   @relation(fields: [leagueId], references: [id])
  occurrences SessionOccurrence[]
  assignments SlotAssignment[]

  @@index([status])
  @@index([leagueId, status])
}

model SessionOccurrence {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @db.Uuid
  startsAt   DateTime
  endsAt     DateTime
  status     SessionOccurrenceStatus @default(ACTIVE)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  session    Session  @relation(fields: [sessionId], references: [id])
  registrations SessionRegistration[]
  subSignups  SubSignup[]
  notifications Notification[]

  @@unique([sessionId, startsAt])
  @@index([sessionId, startsAt, status])
}

model SlotAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  leagueId  String   @db.Uuid
  userId    String   @db.Uuid
  sessionId String   @db.Uuid
  createdAt DateTime @default(now())
  league    League   @relation(fields: [leagueId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  session   Session  @relation(fields: [sessionId], references: [id])

  @@unique([leagueId, userId])
  @@index([sessionId])
  @@index([userId, sessionId])
}

model SessionRegistration {
  id           String             @id @default(uuid()) @db.Uuid
  userId       String             @db.Uuid
  occurrenceId String             @db.Uuid
  status       RegistrationStatus
  updatedAt    DateTime           @updatedAt
  createdAt    DateTime           @default(now())
  user         User               @relation(fields: [userId], references: [id])
  occurrence   SessionOccurrence  @relation(fields: [occurrenceId], references: [id])

  @@unique([userId, occurrenceId])
  @@index([occurrenceId, status])
  @@index([userId, status])
}

model SubSignup {
  id         String          @id @default(uuid()) @db.Uuid
  userId     String          @db.Uuid
  occurrenceId String        @db.Uuid
  status     SubSignupStatus
  signedUpAt DateTime        @default(now())
  selectionRank Int?
  selectedAt DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  user       User            @relation(fields: [userId], references: [id])
  occurrence SessionOccurrence @relation(fields: [occurrenceId], references: [id])

  @@unique([userId, occurrenceId])
  @@index([occurrenceId, status, signedUpAt])
  @@index([userId, status])
}

model Notification {
  id         String              @id @default(uuid()) @db.Uuid
  userId     String              @db.Uuid
  occurrenceId  String?          @db.Uuid
  title      String
  body       String
  channel    NotificationChannel
  status     NotificationStatus
  kind       NotificationKind
  payload    Json?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  user       User                @relation(fields: [userId], references: [id])
  occurrence SessionOccurrence?  @relation(fields: [occurrenceId], references: [id])
}
