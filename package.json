{
	"name": "hbk-pickle-api",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm exec nodemon --watch src --ext ts --exec \"pnpm exec tsx src/app/server.ts\"",
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"format": "prettier --write \"**/*.{ts,json,md,yml,yaml}\"",
		"prisma": "prisma",
		"start": "node dist/app/server.js",
		"scheduler:tick": "pnpm exec tsx src/jobs/schedulers/registrationTick.ts",
		"scheduler:loop": "pnpm exec tsx src/jobs/schedulers/registrationTicker.ts",
		"worker:notifications": "pnpm exec tsx src/jobs/notificationWorker.ts",
		"worker:sub-selection": "pnpm exec tsx src/jobs/subSelectionWorker.ts"
	},
	"dependencies": {
		"@graphql-tools/schema": "^10.0.2",
		"@prisma/client": "6.8.2",
		"apollo-server-express": "^3.13.0",
		"bullmq": "^5.11.0",
		"cors": "^2.8.5",
		"dotenv": "^16.4.5",
		"express": "^4.19.2",
		"firebase-admin": "^12.2.0",
		"graphql": "^16.9.0",
		"graphql-scalars": "^1.23.0",
		"ioredis": "^5.5.0",
		"jsonwebtoken": "^9.0.2",
		"pino": "^9.3.1",
		"pino-http": "^9.0.0",
		"twilio": "^5.4.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.3",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/jsonwebtoken": "^9.0.6",
		"@types/node": "^20.14.10",
		"@typescript-eslint/eslint-plugin": "^8.4.0",
		"@typescript-eslint/parser": "^8.4.0",
		"eslint": "^9.10.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-import": "^2.29.1",
		"eslint-plugin-unused-imports": "^4.1.3",
		"nodemon": "^3.1.4",
		"prettier": "^3.3.3",
		"prisma": "6.8.2",
		"tsx": "^4.19.0",
		"typescript": "^5.6.2"
	},
	"pnpm": {
		"overrides": {
			"@types/express": "4.17.25",
			"@types/express-serve-static-core": "4.17.31"
		}
	}
}
